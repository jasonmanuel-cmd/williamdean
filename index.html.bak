      "AI Walk-Through Videos"
    ],
    "sameAs": [
      "https://instagram.com/williamdeanrealphotography"
    ]
  }
  </script>
  <style>
    :root{
      --bg:#0f1115;
      --card:#171a21;
      --text:#eef2ff;
      --muted:#b8c0d9;
      --accent:#d7b26d;
      --accent-2:#f1d7a3;
      --line:rgba(255,255,255,.12);
      --shadow:0 20px 40px rgba(0,0,0,.35);
      --radius:18px;
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;font-family:Inter,Segoe UI,system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text)}
    a{text-decoration:none;color:inherit}
    .container{width:min(1180px,92vw);margin:0 auto}
    .btn{
      display:inline-block;padding:14px 22px;border-radius:999px;
      font-weight:700;letter-spacing:.2px;transition:.25s ease;cursor:pointer
    }
    .btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#111}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 25px rgba(215,178,109,.35)}
    .btn-ghost{border:1px solid var(--line);color:var(--text)}
    .btn-ghost:hover{background:rgba(255,255,255,.06)}
    header{
      position:sticky;top:0;z-index:20;backdrop-filter:blur(15px);
      background:rgba(15,17,21,.85);border-bottom:1px solid var(--line)
    }
    .nav-grid{
      display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:12px 0
    }
    .header-center{display:flex;align-items:center;gap:20px;justify-content:center}
    .header-right{display:flex;justify-content:flex-end}
    .nav-phone{font-weight:800;color:var(--accent);font-size:1.25rem;letter-spacing:0.5px}
    .chat-trigger{
      background:rgba(255,255,255,.05);border:1px solid var(--line);color:var(--text);
      padding:10px 18px;border-radius:999px;font-weight:700;cursor:pointer;transition:.2s;
      display:flex;align-items:center;gap:8px;font-size:0.95rem
    }
    .chat-trigger:hover{background:rgba(255,255,255,.1);border-color:var(--accent)}
    .hero{
      position:relative;
      overflow:hidden;
      padding:20px 0 60px; /* Tighter gap to header */
      background:#000;
      min-height:85vh;display:flex;justify-content:center;align-items:flex-start
    }
    .hero-bg{
      position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:0;
      animation:heroZoom 30s ease-in-out infinite alternate;
      opacity:0.75;
    }
    @keyframes heroZoom {
      0% { transform: scale(1); filter: brightness(0.6) saturate(1); }
      100% { transform: scale(1.15); filter: brightness(0.65) saturate(1.1); }
    }
    .hero::before{
      content:"";
      position:absolute;inset:0;
      background:
        radial-gradient(circle at 20% 30%, rgba(255,255,255,.28) 0 2px, transparent 3px),
        radial-gradient(circle at 78% 18%, rgba(215,178,109,.28) 0 2px, transparent 3px),
        radial-gradient(circle at 65% 62%, rgba(255,255,255,.2) 0 2px, transparent 3px),
        radial-gradient(circle at 33% 74%, rgba(215,178,109,.2) 0 2px, transparent 3px),
        radial-gradient(circle at 88% 72%, rgba(255,255,255,.16) 0 2px, transparent 3px);
      background-size:220px 220px,260px 260px,300px 300px,240px 240px,340px 340px;
      animation:floatStars 18s linear infinite;
      opacity:.7;
      z-index:0;
      pointer-events:none;
    }
    .hero::after{
      content:"";
      position:absolute;inset:0;
      background:radial-gradient(circle at center, rgba(0,0,0,0) 0%, rgba(0,0,0,.35) 78%);
      z-index:0;
      pointer-events:none;
    }
    @keyframes floatStars{
      0%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-14px) translateX(10px)}
      100%{transform:translateY(0) translateX(0)}
    }
    .hero-card{
      position:relative;z-index:2;text-align:center;
      width:min(800px,100%);background:rgba(15,17,21,.72);border:1px solid var(--line);
      border-radius:24px;padding:40px;box-shadow:0 30px 60px rgba(0,0,0,.5);
      backdrop-filter:blur(10px)
    }
    .hero-logo{
      width:220px; /* Slightly punchier logo size */
      margin-bottom:30px;
      filter: drop-shadow(0 0 40px rgba(215,178,109,0.25)) drop-shadow(0 15px 30px rgba(0,0,0,.8));
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-card:hover .hero-logo { transform: scale(1.03) translateY(-5px); }
    h1{font-size:clamp(2rem,4vw,3.4rem);line-height:1.1;margin:0 0 14px}
    .lead{font-size:1.1rem;color:var(--muted);line-height:1.65;margin:0 0 24px}
    .cta-row{display:flex;gap:12px;flex-wrap:wrap}
    section{padding:64px 0}
    .section-title{font-size:clamp(1.6rem,2.8vw,2.2rem);margin:0 0 12px}
    .section-sub{color:var(--muted);margin:0 0 30px;line-height:1.7}
    .proof{
      display:grid;grid-template-columns:repeat(3,1fr);gap:16px
    }
    .bio-grid{
      display:grid;grid-template-columns:360px 1fr;gap:24px;align-items:stretch
    }
    .bio-photo{
      border:1px solid var(--line);border-radius:14px;overflow:hidden;background:var(--card)
    }
    .bio-photo img{width:100%;height:100%;object-fit:cover;display:block;min-height:420px}
    .pill{
      display:inline-block;padding:7px 12px;border:1px solid var(--line);border-radius:999px;
      color:var(--muted);font-size:.88rem;margin:0 8px 8px 0
    }
    .proof .item{
      background:var(--card);border:1px solid var(--line);border-radius:14px;padding:20px
    }
    .proof .num{font-size:1.8rem;font-weight:800;color:var(--accent)}
    .gallery{
      display:grid;grid-template-columns:repeat(4,1fr);gap:12px
    }
    .gallery img{
      width:100%;height:220px;object-fit:cover;border-radius:14px;border:1px solid var(--line);
      transition:.3s ease;box-shadow:var(--shadow)
    }
    .gallery img:hover{transform:translateY(-4px) scale(1.01)}
    .process{
      display:grid;grid-template-columns:repeat(3,1fr);gap:16px
    }
    .card{
      background:var(--card);border:1px solid var(--line);border-radius:14px;padding:20px
    }
    .card h3{margin:0 0 8px}
    .card p{margin:0;color:var(--muted);line-height:1.7}
    .closing{
      background:
        linear-gradient(135deg,rgba(215,178,109,.13),rgba(255,255,255,.03));
      border:1px solid var(--line);border-radius:20px;padding:34px
    }
    .quotes{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:40px}
    .quote-card{background:rgba(255,255,255,.03);border:1px solid var(--line);padding:24px;border-radius:14px;font-style:italic}
    .quote-author{display:block;margin-top:12px;font-style:normal;font-weight:700;color:var(--accent);font-size:.9rem}
    .faq-grid{display:grid;gap:16px;margin-top:30px}
    .faq-item{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:24px}
    .faq-item h3{margin:0 0 10px;font-size:1.15rem;color:var(--accent-2)}
    .faq-item p{margin:0;line-height:1.6;color:var(--muted)}
    footer{padding:32px 0;color:var(--muted);border-top:1px solid var(--line);margin-top:52px}
    @media (max-width:980px){
      .gallery{grid-template-columns:repeat(2,1fr)}
      .proof,.process,.bio-grid{grid-template-columns:1fr}
      .hero{min-height:72vh}
    }
    @media (max-width:560px){
      .gallery img{height:180px}
    }
    /* Starfield canvas sits behind page content but above the page background */
    #starfield{position:fixed;inset:0;display:block;pointer-events:none;z-index:0;width:100%;height:100%}
    /* Ensure page content renders above the starfield */
    body > *:not(#starfield):not(.splash-screen){position:relative;z-index:1}

    /* Splash Screen Styles */
    .splash-screen {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: var(--bg);
      display: flex;
      overflow: hidden;
      pointer-events: all;
    }
    .splash-door {
      position: absolute;
      top: 0;
      width: 50%;
      height: 100%;
      background: var(--bg);
      display: flex;
      align-items: center;
      transition: transform 0.8s cubic-bezier(0.7, 0, 0.3, 1);
      z-index: 2;
    }
    .door-left {
      left: 0;
      justify-content: flex-end;
      border-right: 1px solid var(--line);
    }
    .door-right {
      right: 0;
      justify-content: flex-start;
      border-left: 1px solid var(--line);
    }
    .splash-logo-half {
      width: 240px; /* Increased for premium impact */
      height: 240px;
      object-fit: contain;
      pointer-events: none;
    }
    .door-left .splash-logo-half {
      object-position: left;
      clip-path: inset(0 50% 0 0);
      transform: translateX(50%);
    }
    .door-right .splash-logo-half {
      object-position: right;
      clip-path: inset(0 0 0 50%);
      transform: translateX(-50%);
    }
    .camera-flash {
      position: fixed;
      inset: 0;
      background: #fff;
      z-index: 10000;
      opacity: 0;
      pointer-events: none;
    }
    .splash-screen.active .door-left { transform: translateX(-100%); }
    .splash-screen.active .door-right { transform: translateX(100%); }

    @keyframes cameraFlash {
      0% { opacity: 0; }
      10% { opacity: 1; }
      100% { opacity: 0; }
    }
    .flash-animate {
      animation: cameraFlash 0.6s ease-out forwards;
    }
    body.locked { overflow: hidden; }
  </style>
</head>
<body class="locked">
  <div class="splash-screen" id="splash">
    <div class="splash-door door-left">
      <img src="billylogo.jpg" class="splash-logo-half" alt="">
    </div>
    <div class="splash-door door-right">
      <img src="billylogo.jpg" class="splash-logo-half" alt="">
    </div>
    <div class="camera-flash" id="flash"></div>
  </div>
  <a class="skip-link" href="#main">Skip to main content</a>
  <canvas id="starfield" aria-hidden="true"></canvas>
  
  <!-- Chat Window Components -->
  <div class="chat-window" id="chatWindow">
    <div class="chat-header">
      <div style="display:flex;align-items:center;gap:10px">
        <div class="status-dot"></div>
        <style>
          .status-dot { width:10px; height:10px; background:#4ade80; border-radius:50%; position:relative; box-shadow: 0 0 10px #4ade80; }
          .status-dot::after {
            content: ""; position: absolute; inset: -3px; border-radius: 50%;
            border: 2px solid #4ade80; animation: dotPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
          }
          @keyframes dotPulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.8); opacity: 0; } }
        </style>
        <strong>Studio Concierge</strong>
      </div>
      <button class="chat-close" onclick="toggleChat()">×</button>
    </div>
    <div class="chat-body" id="chatBody">
      <div class="msg bot">Welcome to William Dean Photography. I'm your Concierge. How can I help you with your Bakersfield listing visibility today?</div>
    </div>
    <div class="chat-footer">
      <input type="text" id="chatInput" placeholder="Ask about pricing or scheduling..." onkeypress="if(event.key==='Enter') handleChatSend()">
      <button onclick="handleChatSend()">Send</button>
    </div>
  </div>

  <style>
    .chat-window {
      position: fixed; top: 75px; 
      /* Dynamic positioning to align with the trigger on the right side of the container */
      right: calc((100vw - min(1180px, 92vw)) / 2 + 10px);
      width: 380px; height: 500px; 
      background: var(--card); border: 1px solid var(--line);
      border-radius: 20px; box-shadow: 0 30px 60px rgba(0,0,0,.6);
      display: none; flex-direction: column; z-index: 100;
      backdrop-filter: blur(20px);
    }
    .chat-window.active { display: flex; animation: slideUp 0.3s ease-out; }
    @keyframes slideUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
    .chat-header { padding: 16px 20px; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,.03); }
    .chat-body { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
    .msg { padding: 10px 14px; border-radius: 14px; max-width: 85%; font-size: 0.95rem; line-height: 1.4; }
    .bot { background: rgba(255,255,255,.07); align-self: flex-start; color: var(--text); border-bottom-left-radius: 2px; }
    .user { background: var(--accent); color: #111; align-self: flex-end; font-weight: 600; border-bottom-right-radius: 2px; }
    .chat-footer { padding: 15px; border-top: 1px solid var(--line); display: flex; gap: 10px; }
    .chat-footer input { flex: 1; background: rgba(0,0,0,.3); border: 1px solid var(--line); color: #fff; padding: 10px 14px; border-radius: 10px; outline: none; }
    .chat-footer button { background: var(--accent); border: none; padding: 0 16px; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .chat-close { background: none; border: none; color: var(--muted); font-size: 24px; cursor: pointer; }
  </style>

  <header>
    <div class="container nav-grid">
      <div class="header-left">
         <!-- Left real estate preserved for balance -->
      </div>
      <div class="header-center">
        <a class="nav-phone" href="tel:8653640099">865-364-0099</a>
        <a class="btn btn-primary" href="tel:8653640099">Book a Shoot</a>
      </div>
      <div class="header-right">
        <button class="chat-trigger" onclick="toggleChat()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          Studio Concierge
        </button>
      </div>
    </div>
  </header>

  <main id="main" role="main">

  <section class="hero">
    <picture>
      <img class="hero-bg" src="60e70c7a-8a69-45e9-bfed-e478c49201c7.jpg" alt="Bakersfield real estate photography - Center of attention Kern County listing" loading="eager" decoding="sync" fetchpriority="high" width="1024" height="1024" aria-hidden="true">
    </picture>
    <div class="container">
      <div class="hero-card">
        <img src="billylogo.jpg" alt="William Dean Photography" class="hero-logo">
        <h1>Bakersfield & Kern County Real Estate Photography</h1>
        <p style="font-size:1.4rem;color:var(--accent);margin-top:-10px;margin-bottom:20px;font-weight:800;letter-spacing:1px">CLEAN. FAST. COMPLIANT.</p>
        <p class="lead" style="font-weight:500;color:var(--text)">
          Technically elite listing visuals for Bakersfield agents who demand consistency, speed, and MLS-compliant accuracy.
        </p>
        <div class="cta-row" style="justify-content:center">
          <a class="btn btn-primary" href="tel:8653640099">Book Shoot: 865-364-0099</a>
          <a class="btn btn-ghost" href="#portfolio">View Work</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 class="section-title">Why Bakersfield Agents Hire William Dean</h2>
      <p class="section-sub">Standardized excellence for the Bakersfield market. Perception shapes price—your listing competes on emotion, trust, and first-scroll impact.</p>
      <div class="proof">
        <div class="item">
          <div class="num">📍 Kern Local</div>
          <p>Serving: Bakersfield, Oildale, Rosedale, Northwest/Southwest/East Bakersfield, Shafter, Wasco, Delano, and surrounding communities.</p>
        </div>
        <div class="item">
          <div class="num">24HR</div>
          <p>Next-day delivery of MLS-ready assets so your listing hit the market while the lead is hot. Zero friction from shoot to upload.</p>
        </div>
        <div class="item">
          <div class="num">100%</div>
          <p>MLS Compliant visuals. No over-processed "HDR glow" or distorted lenses—just clean lines and accurate light that agents trust.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="bio">
    <div class="container">
      <h2 class="section-title">Who You’re Hiring — and Why That Matters</h2>
      <p class="section-sub">This is not just someone with a camera. This is a craft-driven operator built on discipline, speed, and detail.</p>
      <div class="bio-grid">
        <div class="bio-photo">
          <img src="billyprofile.png" alt="William Dean profile portrait" />
        </div>
        <div class="card">
          <h3>William Dean Photography</h3>
          <p class="section-sub" style="margin:10px 0 16px;">
            William is a veteran tattooer and professional photographer working under the same roof in Downtown Bakersfield. Tattooing taught him permanence, precision, patience, and respect for light. Real estate photography became the next expression of that same standard: no gimmicks, no overcooked edits, just honest light, clean lines, and visual control that helps agents win trust faster.
          </p>
          <div>
            <span class="pill">@williamdeanrealphotography</span>
            <span class="pill">Serving Bakersfield & Kern County</span>
            <span class="pill">Fast Turnaround</span>
            <span class="pill">MLS Compliant</span>
            <span class="pill">Residential + Commercial</span>
            <span class="pill">Twilight + AI Add-ons</span>
          </div>
          <p style="margin-top:18px;color:var(--muted);line-height:1.7;">
            Psychological edge for your listings: buyers decide in seconds whether a home feels credible, elevated, and worth acting on. Clean verticals, accurate white balance, balanced window pulls, and emotionally tuned marketing visuals drive that decision before logic even starts. That is where William’s work creates leverage.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="portfolio">
    <div class="container">
      <h2 class="section-title">Portfolio: Technically Clean, Emotionally Dialed</h2>
      <p class="section-sub">Clean HDR images, sharp verticals, balanced natural/interior light, and listing visuals that are both MLS-safe and social-media effective.</p>
      <div class="gallery">
        <picture>
          <img src="3ecd8fa8-11a5-4384-882a-7a66f2daf94e.jpg" alt="Bakersfield real estate interior photography - living room" width="2048" height="1367" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="43f0ef02-eefb-4f8f-a17c-0d54af0f1097.jpg" alt="Bakersfield real estate kitchen photo - clean verticals" width="2048" height="1367" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="60e70c7a-8a69-45e9-bfed-e478c49201c7.jpg" alt="Kern County residential listing photo - master suite" width="2048" height="1535" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="a8e10692-14c7-4f17-8634-850d82c114c4.jpg" alt="Bakersfield Real Estate Photography - Entryway" width="1024" height="1536" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="b087f1f0-3d18-43ad-9169-3bb1ea134e18.jpg" alt="Bakersfield home listing photo - living space" width="1536" height="1024" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="bdae2579-a8cc-44d9-a09c-7e082cc7ddca.jpg" alt="Real estate photography - Modern Bakersfield kitchen" width="2048" height="1535" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="cfd04b7d-df76-4477-87c7-2c05c8b128f8.jpg" alt="Professional listing photo - Bakersfield CA" width="2048" height="1367" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="e3983ca3-d30b-49b0-9b80-4559aa1f984c.jpg" alt="Real estate photo - Kern County" width="1536" height="1024" loading="lazy" decoding="async">
        </picture>
        <picture>
          <img src="ec8cc0e9-74b8-49ff-a569-f397f836a75d.jpg" alt="Bakersfield residential interior photo" width="1536" height="1024" loading="lazy" decoding="async">
