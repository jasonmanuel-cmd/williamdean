  <meta name="ICBM" content="35.3733, -119.0187" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "name": "William Dean Photography",
    "image": "https://williamdeanphotography.com/billylogo.jpg",
    "description": "Real estate photographer in Bakersfield & Kern County delivering clean, fast, MLS-compliant listing photos, twilight edits, and AI-enhanced marketing visuals.",
    "url": "https://williamdeanphotography.com/",
    "telephone": "+1-865-364-0099",
    "email": "williamdeanrealphotography@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bakersfield",
      "addressRegion": "CA",
      "postalCode": "93301",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 35.3733,
      "longitude": -119.0187
    },
    "areaServed": [
      {
        "@type": "City",
        "name": "Bakersfield"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Kern County"
      }
    ],
    "serviceType": [
      "Residential Real Estate Photography",
      "Commercial Real Estate Photography",
      "MLS-Compliant Listing Photography",
      "Twilight Edits",
