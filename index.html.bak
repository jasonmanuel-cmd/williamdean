  <script>
    (function(){
      const canvas = document.getElementById('starfield');
      const ctx = canvas.getContext('2d');
      let stars = [];
      const getCount = () => Math.max(60, Math.floor((window.innerWidth * window.innerHeight) / 9000));
      function resize(){
        const dpr = window.devicePixelRatio || 1;
        canvas.width = Math.floor(window.innerWidth * dpr);
        canvas.height = Math.floor(window.innerHeight * dpr);
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.setTransform(dpr,0,0,dpr,0,0);
        initStars();
      }
      function initStars(){
        const count = getCount();
        stars = new Array(count).fill(0).map(()=>({
          x: Math.random()*window.innerWidth,
          y: Math.random()*window.innerHeight,
          r: Math.random()*1.3 + 0.3,
          alpha: Math.random()*0.9 + 0.1,
          twinkle: Math.random()*0.03 + 0.004,
          phase: Math.random()*Math.PI*2
        }));
      }
      function draw(){
        ctx.clearRect(0,0,canvas.width,canvas.height);
        for(const s of stars){
          s.phase += s.twinkle;
          const a = s.alpha * (0.55 + 0.45 * Math.sin(s.phase));
          ctx.beginPath();
          ctx.fillStyle = `rgba(255,255,255,${a.toFixed(3)})`;
          ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
          ctx.fill();
        }
        requestAnimationFrame(draw);
      }
      window.addEventListener('resize', resize);

      function startStarfield(){
        // start drawing after critical paint
        resize();
        draw();
      }

      function scheduleStart(){
        if ('requestIdleCallback' in window){
          requestIdleCallback(startStarfield, {timeout:2000});
        } else {
          setTimeout(startStarfield, 1000);
        }
      }

      if (document.readyState === 'complete') scheduleStart();
      else window.addEventListener('load', scheduleStart, {once:true});
    })();
  </script>
    <script>
      // Accessibility & performance helpers
      (function(){
        // Ensure focus outlines are visible for keyboard users
        const style = document.createElement('style');
        style.textContent = `
          .skip-link{position:absolute;left:-999px;top:auto;width:1px;height:1px;overflow:hidden}
          .skip-link:focus{position:fixed;left:12px;top:12px;width:auto;height:auto;padding:8px 12px;background:#111;color:#fff;z-index:40;border-radius:6px}
          a:focus, button:focus{outline:3px solid rgba(215,178,109,.85);outline-offset:3px}
        `;
        document.head.appendChild(style);

        // Add lazy-loading and decoding to gallery images
        document.querySelectorAll('.gallery img, .bio-photo img').forEach(img=>{
          if(!img.hasAttribute('loading')) img.setAttribute('loading','lazy');
          if(!img.hasAttribute('decoding')) img.setAttribute('decoding','async');
        });

        // CTA tracking (GA4 placeholder). Replace G-XXXX with your measurement ID.
        function trackEvent(action, label){
          if(window.gtag) gtag('event', action, {event_label: label});
          else console.log('GA4 event:', action, label);
        }
        document.querySelectorAll('a.btn').forEach(a=>{
          a.addEventListener('click', e=>{
            const label = a.href || a.getAttribute('href') || a.textContent.trim();
            trackEvent('cta_click', label);
          });
        });
      })();
    </script>

    <!-- GA4 placeholder: replace MEASUREMENT_ID with your G-XXXXXXX ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=MEASUREMENT_ID"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments)}
      gtag('js', new Date());
      gtag('config', 'MEASUREMENT_ID');
    </script>
    <script>
      // Chat system logic
      function toggleChat() {
        const win = document.getElementById('chatWindow');
        win.classList.toggle('active');
        if(win.classList.contains('active')) {
          document.getElementById('chatInput').focus();
        }
      }

      function handleChatSend() {
        const input = document.getElementById('chatInput');
        const body = document.getElementById('chatBody');
        const text = input.value.trim();
        if(!text) return;

        // User message
        const userMsg = document.createElement('div');
        userMsg.className = 'msg user';
        userMsg.textContent = text;
        body.appendChild(userMsg);
        input.value = '';
        body.scrollTop = body.scrollHeight;

        // Bot response
        setTimeout(() => {
          const botMsg = document.createElement('div');
          botMsg.className = 'msg bot';
          botMsg.textContent = getBotResponse(text);
          body.appendChild(botMsg);
          body.scrollTop = body.scrollHeight;
        }, 600);
      }

      function getBotResponse(input) {
        const low = input.toLowerCase();
        if(low.includes('price') || low.includes('cost') || low.includes('how much')) {
          return "Most Bakersfield residential shoots range from $175 to $350 depending on square footage and add-ons like twilight or AI staging. Would you like a precise quote?";
        }
        if(low.includes('schedul') || low.includes('book') || low.includes('when')) {
          return "I can typically get you on the Bakersfield schedule within 48 hours. Delivery is guaranteed within 24 hours of the shoot. What day are you looking at?";
        }
        if(low.includes('area') || low.includes('kern') || low.includes('serve')) {
          return "William serves all of Bakersfield and Kern County, including Rosedale, Shafter, Wasco, and Tehachapi. No travel fees within the Bakersfield metro area.";
        }
        return "I'm the Studio Concierge. I can help with pricing, scheduling, or service areas for your Bakersfield listings. What can I clarify for you?";
      }

      // Splash Screen Logic
      (function(){
        const splash = document.getElementById('splash');
        const flash = document.getElementById('flash');
        const body = document.body;

        function triggerSplash(){
          setTimeout(() => {
            flash.classList.add('flash-animate');
            setTimeout(() => {
              splash.classList.add('active');
              body.classList.remove('locked');
              setTimeout(() => {
                splash.style.display = 'none';
              }, 800);
            }, 60);
          }, 1200);
        }

        if (document.readyState === 'complete') triggerSplash();
        else window.addEventListener('load', triggerSplash);
      })();
    </script>
</body>
